{
  "name": "server",
  "version": "0.0.1",
  "description": "Node based server for Spikeball game dashboard",
  "author": "Md Samsuzzoha <mdsamsuzzoha@gmail.com>",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "export NODE_ENV=production && nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "dev": "export NODE_ENV=development && nest start --watch",
    "load-balancer": "nodemon load-balancer.js",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/server/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/server/test/jest-e2e.json",
    "dev:pm2:start": "pm2 start ecosystem.dev.config.js",
    "dev:pm2:stop": "pm2 delete ecosystem.dev.config.js",
    "dev:pm2:list": "pm2 list",
    "dev:pm2:logs": "pm2 logs",
    "dev:pm2:status": "pm2 status",
    "dev:pm2:restart": "pm2 restart all"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/platform-socket.io": "11.1.9",
    "@nestjs/platform-ws": "^11.1.9",
    "@nestjs/websockets": "^11.1.9",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/html-to-text": "^9.0.4",
    "bcrypt": "^6.0.0",
    "class-validator": "^0.14.3",
    "cloudinary": "^2.8.0",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-session": "^1.18.2",
    "express-socket.io-session": "^1.3.5",
    "graphql": "^16.12.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-upload": "^17.0.0",
    "handlebars": "^4.7.8",
    "html-to-text": "^9.0.5",
    "i": "^0.3.7",
    "ioredis": "^5.8.2",
    "isomorphic-dompurify": "^3.0.0",
    "mongoose": "^9.0.1",
    "nodemailer": "^7.0.11",
    "npm": "^11.7.0",
    "papaparse": "^5.5.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1",
    "socket.io-redis": "^6.1.1",
    "uninstall": "^0.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/graphql-upload": "^17.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "25.0.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-nestjs": "^0.8.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "http-proxy": "^1.18.1",
    "jest": "30.2.0",
    "nodemon": "^3.1.11",
    "pm2": "^6.0.14",
    "prettier": "^3.7.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-jest": "29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
